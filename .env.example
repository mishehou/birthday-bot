# ── WhatsApp linked device ───────────────────────────────────────────────────
# Secret key shared between the birthday-bot and the evolution-api containers.
# Choose any random string — it never leaves your Synology.
EVOLUTION_API_KEY=birthday-bot-key

# Who receives the birthday messages.
# Use the phone number WITH country code, WITHOUT the leading +
# Multiple recipients: comma-separated
WHATSAPP_RECIPIENTS=972501234567

# ── Schedule ─────────────────────────────────────────────────────────────────
NOTIFICATION_HOUR=9
NOTIFICATION_MINUTE=0
TIMEZONE=Asia/Jerusalem

# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
